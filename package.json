{
  "name": "wild-go-mvp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "ios:build": "xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -derivedDataPath ios/App/build-native CODE_SIGNING_ALLOWED=NO build",
    "ios:smoke": "npm run ios:build && ios/qa-smoke.sh",
    "ios:verify-events": "ios/qa-check-events.sh",
    "ios:interactions": "ios/qa-check-events.sh && npm run ios:build && ios/qa-interactions.sh",
    "ios:open": "open ios/App/App.xcodeproj"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "5.0.4",
    "card-foil": "^0.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-parallax-tilt": "^1.7.333",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "6.4.2"
  }
}
