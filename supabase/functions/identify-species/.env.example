# Copy to .env.local for direct/local runs. Deploy only OPENAI_API_KEY and
# OPENAI_VISION_MODEL with `supabase secrets set` (see supabase/deploy.sh).
# Never commit the filled-in copy.

# Required for real cloud recognition. Without it the function returns a
# configuration error unless ALLOW_DEMO_IDENTIFICATION=true is set for local demos.
OPENAI_API_KEY=sk-...

# Optional. Defaults to gpt-4.1-mini.
OPENAI_VISION_MODEL=gpt-4.1-mini

# Supabase injects the following variables automatically for hosted functions
# and CLI-managed local functions. Fill them only for a direct Deno or
# self-hosted run that does not provide the Supabase runtime environment.
# Service role key: used to upload to private Storage and write observations.
SUPABASE_SERVICE_ROLE_KEY=...

# Anon key: used to verify signed-in user JWTs before trusting user_id.
SUPABASE_ANON_KEY=...
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Set to true ONLY for local demos without an OpenAI key. Leave unset in prod.
# ALLOW_DEMO_IDENTIFICATION=false
